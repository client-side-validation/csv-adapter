        let block_data = self.fetch_block(block).await?;
        let mut seals = Vec::new();

        for tx in &block_data.tx {
            for vin in &tx.vin {
                if let (Some(ref prev_txid), Some(prev_vout)) = (&vin.txid, vin.vout) {

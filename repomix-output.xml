<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy" content="default-src 'none'; style-src 'unsafe-inline'; script-src 'unsafe-inline' https://cdn.jsdelivr.net;">
  <title>CSV Proof Visualizer</title>
  <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
  <style>
    :root {
      --bg-primary: var(--vscode-editor-background, #1e1e1e);
      --bg-secondary: var(--vscode-editorWidget-background, #252526);
      --bg-tertiary: var(--vscode-dropdown-background, #3c3c3c);
      --text-primary: var(--vscode-foreground, #cccccc);
      --text-secondary: var(--vscode-descriptionForeground, #999999);
      --border-color: var(--vscode-panel-border, #454545);
      --accent-color: var(--vscode-textLink-foreground, #3794ff);
      --success-color: var(--vscode-terminal-ansiGreen, #89d185);
      --warning-color: var(--vscode-terminal-ansiYellow, #cca700);
      --error-color: var(--vscode-terminal-ansiRed, #f14c4c);
      --info-color: var(--vscode-terminal-ansiBlue, #3794ff);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: var(--vscode-font-family, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif);
      font-size: var(--vscode-font-size, 13px);
      color: var(--text-primary);
      background: var(--bg-primary);
      line-height: 1.5;
      padding: 16px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border-color);
    }

    .header h1 {
      font-size: 1.2em;
      font-weight: 600;
    }

    .header-actions {
      display: flex;
      gap: 8px;
    }

    .btn {
      padding: 6px 12px;
      border: 1px solid var(--border-color);
      border-radius: 4px;
      background: var(--bg-tertiary);
      color: var(--text-primary);
      cursor: pointer;
      font-size: 0.9em;
      transition: background 0.2s;
    }

    .btn:hover {
      background: var(--accent-color);
      color: white;
    }

    .btn:active {
      opacity: 0.8;
    }

    .btn-primary {
      background: var(--accent-color);
      color: white;
      border-color: var(--accent-color);
    }

    .container {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 16px;
      height: calc(100vh - 100px);
    }

    .sidebar {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      padding: 12px;
      overflow-y: auto;
    }

    .main-content {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .section-title {
      font-size: 0.85em;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-secondary);
      margin-bottom: 8px;
    }

    .proof-list {
      list-style: none;
    }

    .proof-item {
      padding: 8px;
      margin-bottom: 4px;
      border-radius: 4px;
      cursor: pointer;
      border-left: 3px solid transparent;
      transition: all 0.2s;
    }

    .proof-item:hover {
      background: var(--bg-tertiary);
    }

    .proof-item.selected {
      background: var(--bg-tertiary);
      border-left-color: var(--accent-color);
    }

    .proof-item .right-id {
      font-family: var(--vscode-editor-font-family, 'Consolas', 'Monaco', monospace);
      font-size: 0.85em;
      color: var(--accent-color);
    }

    .proof-item .meta {
      font-size: 0.8em;
      color: var(--text-secondary);
      margin-top: 4px;
    }

    .visualization-area {
      flex: 1;
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      padding: 16px;
      overflow: auto;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .mermaid {
      max-width: 100%;
    }

    .proof-details {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      padding: 16px;
    }

    .verification-steps {
      list-style: none;
      counter-reset: step;
    }

    .step {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 10px;
      margin-bottom: 6px;
      border-radius: 4px;
      counter-increment: step;
    }

    .step::before {
      content: counter(step);
      display: flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      font-weight: 600;
      font-size: 0.85em;
      flex-shrink: 0;
    }

    .step.valid {
      background: color-mix(in srgb, var(--success-color) 10%, transparent);
      border-left: 3px solid var(--success-color);
    }

    .step.valid::before {
      background: var(--success-color);
      color: white;
    }

    .step.invalid {
      background: color-mix(in srgb, var(--error-color) 10%, transparent);
      border-left: 3px solid var(--error-color);
    }

    .step.invalid::before {
      background: var(--error-color);
      color: white;
    }

    .step.pending {
      background: color-mix(in srgb, var(--warning-color) 10%, transparent);
      border-left: 3px solid var(--warning-color);
    }

    .step.pending::before {
      background: var(--warning-color);
      color: white;
    }

    .step-content {
      flex: 1;
    }

    .step-title {
      font-weight: 500;
      margin-bottom: 2px;
    }

    .step-description {
      font-size: 0.85em;
      color: var(--text-secondary);
    }

    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      text-align: center;
      color: var(--text-secondary);
    }

    .empty-state svg {
      width: 64px;
      height: 64px;
      margin-bottom: 16px;
      opacity: 0.5;
    }

    .empty-state h2 {
      font-size: 1.1em;
      margin-bottom: 8px;
      color: var(--text-primary);
    }

    .empty-state p {
      font-size: 0.9em;
      max-width: 300px;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 10px;
      font-size: 0.75em;
      font-weight: 500;
      text-transform: uppercase;
    }

    .status-badge.valid {
      background: color-mix(in srgb, var(--success-color) 20%, transparent);
      color: var(--success-color);
    }

    .status-badge.invalid {
      background: color-mix(in srgb, var(--error-color) 20%, transparent);
      color: var(--error-color);
    }

    .status-badge.pending {
      background: color-mix(in srgb, var(--warning-color) 20%, transparent);
      color: var(--warning-color);
    }

    @media (max-width: 768px) {
      .container {
        grid-template-columns: 1fr;
      }

      .sidebar {
        max-height: 200px;
      }
    }

    /* Accessibility: Focus styles */
    .btn:focus,
    .proof-item:focus {
      outline: 2px solid var(--accent-color);
      outline-offset: 2px;
    }

    /* Reduced motion preference */
    @media (prefers-reduced-motion: reduce) {
      * {
        transition: none !important;
      }
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>CSV Proof Visualizer</h1>
    <div class="header-actions">
      <button class="btn" id="refresh-btn" aria-label="Refresh visualization">Refresh</button>
      <button class="btn btn-primary" id="export-btn" aria-label="Export diagram">Export</button>
    </div>
  </div>

  <div class="container">
    <div class="sidebar" role="navigation" aria-label="Proof list">
      <div class="section-title">Proofs</div>
      <ul class="proof-list" id="proof-list" role="listbox" aria-label="Available proofs">
        <li class="proof-item" tabindex="0" role="option" data-right-id="0xabc123...">
          <div class="right-id">0xabc123...</div>
          <div class="meta">Ethereum &middot; Ownership</div>
        </li>
        <li class="proof-item" tabindex="0" role="option" data-right-id="0xdef456...">
          <div class="right-id">0xdef456...</div>
          <div class="meta">Aptos &middot; Transfer</div>
        </li>
        <li class="proof-item" tabindex="0" role="option" data-right-id="0x789ghi...">
          <div class="right-id">0x789ghi...</div>
          <div class="meta">Sui &middot; Ownership</div>
        </li>
      </ul>
    </div>

    <div class="main-content">
      <div class="visualization-area" id="mermaid-container">
        <div class="empty-state" id="empty-state">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <h2>No Proof Selected</h2>
          <p>Select a proof from the sidebar to visualize its Merkle tree structure and verification path.</p>
        </div>
        <div class="mermaid" id="mermaid-diagram" style="display: none;"></div>
      </div>

      <div class="proof-details" id="proof-details" style="display: none;">
        <div class="section-title">Verification Steps</div>
        <ol class="verification-steps" id="verification-steps">
          <li class="step valid">
            <div class="step-content">
              <div class="step-title">Root Hash Verification</div>
              <div class="step-description">Merkle root matches expected value on chain</div>
            </div>
          </li>
          <li class="step valid">
            <div class="step-content">
              <div class="step-title">Path Validation</div>
              <div class="step-description">Proof path correctly links leaf to root</div>
            </div>
          </li>
          <li class="step valid">
            <div class="step-content">
              <div class="step-title">Signature Verification</div>
              <div class="step-description">Cryptographic signature is valid</div>
            </div>
          </li>
          <li class="step pending">
            <div class="step-content">
              <div class="step-title">Cross-Chain Confirmation</div>
              <div class="step-description">Waiting for destination chain finality</div>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </div>

  <script>
    // Initialize Mermaid
    mermaid.initialize({
      startOnLoad: true,
      theme: document.body.classList.contains('vscode-dark') ? 'dark' : 'default',
      securityLevel: 'loose',
      fontFamily: 'var(--vscode-font-family, sans-serif)',
      fontSize: 12,
    });

    // Sample Mermaid diagram for proof visualization
    const sampleDiagram = `
graph TD
    A[Merkle Root] --> B[Node 1]
    A --> C[Node 2]
    B --> D[Leaf 1]
    B --> E[Leaf 2]
    C --> F[Leaf 3]
    C --> G[Your Right]
    
    style A fill:#89d185,stroke:#fff,color:#000
    style G fill:#3794ff,stroke:#fff,color:#fff
    style F fill:#89d185,stroke:#fff,color:#000
    `;

    // Event handlers
    document.getElementById('refresh-btn').addEventListener('click', function() {
      renderDiagram();
      vscode.postMessage({ command: 'refresh' });
    });

    document.getElementById('export-btn').addEventListener('click', function() {
      vscode.postMessage({ command: 'export' });
    });

    // Proof selection
    document.querySelectorAll('.proof-item').forEach(function(item) {
      item.addEventListener('click', function() {
        document.querySelectorAll('.proof-item').forEach(function(el) {
          el.classList.remove('selected');
        });
        this.classList.add('selected');
        
        const rightId = this.getAttribute('data-right-id');
        document.getElementById('empty-state').style.display = 'none';
        document.getElementById('mermaid-diagram').style.display = 'block';
        document.getElementById('proof-details').style.display = 'block';
        
        renderDiagram(rightId);
        vscode.postMessage({ command: 'selectProof', data: rightId });
      });

      item.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          this.click();
        }
      });
    });

    function renderDiagram(rightId) {
      const container = document.getElementById('mermaid-diagram');
      container.removeAttribute('data-processed');
      container.innerHTML = sampleDiagram;
      
      try {
        mermaid.run({ nodes: [container] });
      } catch (e) {
        container.innerHTML = '<p>Failed to render diagram. Please try again.</p>';
        vscode.postMessage({ command: 'error', data: e.message });
      }
    }

    // Listen for messages from VS Code
    window.addEventListener('message', function(event) {
      const message = event.data;
      
      switch (message.command) {
        case 'updateProofs':
          updateProofList(message.data);
          break;
        case 'selectProof':
          selectProofById(message.data);
          break;
      }
    });

    function updateProofList(proofs) {
      const list = document.getElementById('proof-list');
      list.innerHTML = '';
      
      proofs.forEach(function(proof) {
        const li = document.createElement('li');
        li.className = 'proof-item';
        li.tabIndex = 0;
        li.setAttribute('role', 'option');
        li.setAttribute('data-right-id', proof.rightId);
        li.innerHTML = '<div class="right-id">' + proof.rightId.substring(0, 10) + '...</div>' +
                       '<div class="meta">' + proof.chain + ' &middot; ' + proof.type + '</div>';
        
        li.addEventListener('click', function() {
          this.click();
        });
        li.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            this.click();
          }
        });
        
        list.appendChild(li);
      });
    }

    function selectProofById(rightId) {
      document.querySelectorAll('.proof-item').forEach(function(item) {
        if (item.getAttribute('data-right-id') === rightId) {
          item.click();
        }
      });
    }

    // VS Code API (provided by the webview)
    const vscode = acquireVsCodeApi();
  </script>
</body>
</html>
</file>


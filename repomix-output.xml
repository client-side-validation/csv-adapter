    "scope": "source.rust",
    "body": [
      "// csv: Proof verification",
      "use csv_adapter::{CsvClient, ProofVerifier};",
      "",
      "async fn verify_proof(",
      "    client: &CsvClient,",
      "    right_id: &str,",
      ") -> csv_adapter::Result<bool> {",
      "    let proof = client.get_proof(right_id).await?;",
      "",
      "    let is_valid = ProofVerifier::new()",
      "        .proof(proof)",
      "        .expected_root(\"${1:0x...}\")",
      "        .chain(Chain::${2:Ethereum})",
      "        .verify()",
      "        .await?;",
      "",
      "    if !is_valid {",
      "        return Err(csv_adapter::Error::ProofInvalid(right_id.into()));",
      "    }",
      "",
      "    Ok(is_valid)",
      "}"
    ]
  },
  "Rust Wallet Init": {
    "prefix": "csv-wallet-init",
    "description": "Initialize CSV wallet (Rust)",
    "scope": "source.rust",
    "body": [
      "// csv: Wallet initialization",
      "use csv_adapter::{Wallet, WalletConfig};",
      "",
      "async fn init_wallet() -> csv_adapter::Result<Wallet> {",
      "    let config = WalletConfig::new()",
      "        .with_path(\"${1:./wallet.json}\")",
      "        .with_chain(Chain::Ethereum, \"${2:https://...}\")",
      "        .with_chain(Chain::Aptos, \"${3:https://...}\")",
      "        .with_chain(Chain::Sui, \"${4:https://...}\")",
      "        .network(\"${5:testnet}\");",
      "",
      "    let wallet = Wallet::init(config).await?;",
      "    Ok(wallet)",
      "}"
    ]
  },
  "Rust Error Handling": {
    "prefix": "csv-error-handle",
    "description": "CSV-specific error handling (Rust)",
    "scope": "source.rust",
    "body": [
      "// csv: Error handling for CSV operations",
      "use csv_adapter::{CsvError, ErrorKind};",
      "",
      "async fn safe_operation() -> csv_adapter::Result<()> {",
      "    match ${1:csv_operation}().await {",
      "        Ok(result) => Ok(result),",
      "        Err(e) => match e.kind() {",
      "            ErrorKind::ProofInvalid => {",
      "                eprintln!(\"Invalid proof: {:?}\", e.details());",
      "                Err(e)",
      "            }",
      "            ErrorKind::ChainUnreachable => {",
      "                eprintln!(\"Chain unreachable: {:?}\", e.chain());",
      "                Err(e)",
      "            }",
      "            ErrorKind::RightNotFound => {",
      "                eprintln!(\"Right not found: {:?}\", e.right_id());",
      "                Err(e)",
      "            }",
      "            _ => {",
      "                eprintln!(\"CSV error: {}\", e);",
      "                Err(e)",
      "            }",
      "        },",
      "    }",
      "}"
    ]
  },
  "Rust Client Builder": {
    "prefix": "csv-client-builder",
    "description": "CSV client builder pattern (Rust)",
    "scope": "source.rust",
    "body": [
      "// csv: Client builder pattern",
      "use csv_adapter::CsvClient;",
      "",
      "async fn build_client() -> csv_adapter::Result<CsvClient> {",
      "    let client = CsvClient::builder()",
      "        .network(\"${1:testnet}\")",
      "        .chains(&[Chain::Ethereum, Chain::Aptos, Chain::Sui])",
      "        .rpc(Chain::Ethereum, \"${2:https://...}\")",
      "        .rpc(Chain::Aptos, \"${3:https://...}\")",
      "        .wallet(\"${4:./wallet.json}\")",
      "        .timeout(std::time::Duration::from_secs(${5:30}))",
      "        .retries(${6:3})",
      "        .build()",
      "        .await?;",
      "",
      "    Ok(client)",
      "}"
    ]
  }
}

                println!("⚠️  Invalid network for address: {}", address_str);
                println!("=== Bitcoin Signet UTXO Discovery Test Complete (skipped) ===");
                return;
            }
        },
        Err(e) => {
            println!("⚠️  Invalid address {}: {}", address_str, e);

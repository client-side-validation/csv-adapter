                <button onclick="showPage('contracts')" class="text-blue-400 hover:text-blue-300 mb-4 flex items-center gap-2">
                    ← Back to Contracts
                </button>
                <h2 class="text-2xl font-bold mb-2">Contract Details</h2>
            </div>
            
            <div id="contract-detail-content" class="space-y-6">
                <!-- Populated dynamically -->
            </div>
        </div>

        <!-- Stats Page -->
        <div id="page-stats" class="hidden">
            <h2 class="text-2xl font-bold mb-6">Statistics</h2>
            <div id="stats-detail" class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-800 mt-16">
        <div class="max-w-7xl mx-auto px-4 py-6">
            <div class="flex items-center justify-between text-sm text-gray-500">
                <span>CSV Explorer v0.2.0</span>
                <div class="flex items-center gap-6">
                    <a href="https://github.com/csv-adapter" target="_blank" class="hover:text-gray-300 transition-colors">GitHub</a>
                    <a href="https://docs.csv.dev" target="_blank" class="hover:text-gray-300 transition-colors">Documentation</a>
                    <span class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-green-500"></span>
                        All chains synced
                    </span>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // ==================== Configuration ====================
        // Network configuration
        const NETWORKS = {
            mainnet: {
                apiUrl: 'http://localhost:8080',
                uiPort: 3000,
                label: 'MAINNET',
                color: 'blue'
            },
            testnet: {
                apiUrl: 'http://localhost:8081',
                uiPort: 3001,
                label: 'TESTNET',
                color: 'purple'
            }
        };
        
        let currentNetwork = 'mainnet';
        let API_URL = NETWORKS.mainnet.apiUrl;
        
        // Detect which network we're on based on the current port
        function detectNetwork() {
            const currentPort = window.location.port;
            for (const [network, config] of Object.entries(NETWORKS)) {
                if (config.uiPort == currentPort) {
                    return network;
                }
            }
            return 'mainnet'; // default
        }
        
        // Initialize network
        function initNetwork() {
            currentNetwork = detectNetwork();
            const config = NETWORKS[currentNetwork];
            API_URL = config.apiUrl;
            
            // Update UI
            document.getElementById('network-selector').value = currentNetwork;
            document.getElementById('network-badge').textContent = config.label;
            document.getElementById('network-badge').className = 
                `px-2 py-1 rounded-full text-xs font-bold bg-${config.color}-600/20 text-${config.color}-400 border border-${config.color}-600/30`;
        }
        
        // Switch network
        function switchNetwork() {
            const selectedNetwork = document.getElementById('network-selector').value;
            const config = NETWORKS[selectedNetwork];
            
            if (selectedNetwork !== currentNetwork) {
                // Open the selected network in a new tab/window
                const newUrl = `http://localhost:${config.uiPort}`;
                window.open(newUrl, '_blank');
                showToast(`Opening ${config.label} in new tab`, 'info');
            }
        }
        
        // ==================== External chain explorer URLs ====================
        const CHAIN_EXPLORERS = {
            bitcoin: {
                mainnet: {
                    name: 'Bitcoin',
                    icon: '₿',
                    color: '#f7931a',
                    tx: (hash) => `https://mempool.space/tx/${hash}`,
                    address: (addr) => `https://mempool.space/address/${addr}`,
                    block: (block) => `https://mempool.space/block/${block}`
                },
                testnet: {
                    name: 'Bitcoin Testnet',
                    icon: '₿',
                    color: '#f7931a',
                    tx: (hash) => `https://mempool.space/testnet/tx/${hash}`,
                    address: (addr) => `https://mempool.space/testnet/address/${addr}`,
                    block: (block) => `https://mempool.space/testnet/block/${block}`
                }
            },
            ethereum: {
                mainnet: {
                    name: 'Ethereum',
                    icon: 'Ξ',
                    color: '#627eea',
                    tx: (hash) => `https://etherscan.io/tx/${hash}`,
                    address: (addr) => `https://etherscan.io/address/${addr}`,
                    block: (block) => `https://etherscan.io/block/${block}`
                },
                testnet: {
                    name: 'Ethereum Sepolia',
                    icon: 'Ξ',
                    color: '#627eea',
                    tx: (hash) => `https://sepolia.etherscan.io/tx/${hash}`,
                    address: (addr) => `https://sepolia.etherscan.io/address/${addr}`,
                    block: (block) => `https://sepolia.etherscan.io/block/${block}`
                }
            },
            sui: {
                mainnet: {
                    name: 'Sui',
                    icon: '◇',
                    color: '#4da2ff',
                    tx: (hash) => `https://suiscan.xyz/mainnet/tx/${hash}`,
                    address: (addr) => `https://suiscan.xyz/mainnet/account/${addr}`,
                    block: (block) => `https://suiscan.xyz/mainnet/checkpoint/${block}`
                },
                testnet: {
                    name: 'Sui Testnet',
                    icon: '◇',
                    color: '#4da2ff',
                    tx: (hash) => `https://suiscan.xyz/testnet/tx/${hash}`,
                    address: (addr) => `https://suiscan.xyz/testnet/account/${addr}`,
                    block: (block) => `https://suiscan.xyz/testnet/checkpoint/${block}`
                }
            },
            aptos: {
                mainnet: {
                    name: 'Aptos',
                    icon: '🅰',
                    color: '#2dd8a3',
                    tx: (hash) => `https://explorer.aptoslabs.com/txn/${hash}`,
                    address: (addr) => `https://explorer.aptoslabs.com/account/${addr}`,
                    block: (block) => `https://explorer.aptoslabs.com/block/${block}`
                },
                testnet: {
                    name: 'Aptos Testnet',
                    icon: '🅰',
                    color: '#2dd8a3',
                    tx: (hash) => `https://explorer.aptoslabs.com/txn/${hash}?network=testnet`,
                    address: (addr) => `https://explorer.aptoslabs.com/account/${addr}?network=testnet`,
                    block: (block) => `https://explorer.aptoslabs.com/block/${block}?network=testnet`
                }
            },
            solana: {
                mainnet: {
                    name: 'Solana',
                    icon: '◎',
                    color: '#9945ff',
                    tx: (hash) => `https://solscan.io/tx/${hash}`,
                    address: (addr) => `https://solscan.io/account/${addr}`,
                    block: (block) => `https://solscan.io/block/${block}`
                },
                testnet: {
                    name: 'Solana Devnet',
                    icon: '◎',
                    color: '#9945ff',
                    tx: (hash) => `https://solscan.io/tx/${hash}?cluster=devnet`,
                    address: (addr) => `https://solscan.io/account/${addr}?cluster=devnet`,
                    block: (block) => `https://solscan.io/block/${block}?cluster=devnet`
                }
            }
        };
        
        // Helper to get explorer URL for current network
        function getExplorerUrl(chain, type, hash) {
            const chainExplorers = CHAIN_EXPLORERS[chain.toLowerCase()];
            if (!chainExplorers) return '#';
            const explorer = chainExplorers[currentNetwork] || chainExplorers.mainnet;
            return explorer[type] ? explorer[type](hash) : '#';
        }
        
        function getExplorerName(chain) {
            const chainExplorers = CHAIN_EXPLORERS[chain.toLowerCase()];
            if (!chainExplorers) return chain;
            const explorer = chainExplorers[currentNetwork] || chainExplorers.mainnet;
            return explorer.name;
        }
        
        function getExplorerIcon(chain) {
            const chainExplorers = CHAIN_EXPLORERS[chain.toLowerCase()];
            if (!chainExplorers) return '●';
            const explorer = chainExplorers[currentNetwork] || chainExplorers.mainnet;
            return explorer.icon;
        }
        
        function getExplorerColor(chain) {
            const chainExplorers = CHAIN_EXPLORERS[chain.toLowerCase()];
            if (!chainExplorers) return '#6b7280';
            const explorer = chainExplorers[currentNetwork] || chainExplorers.mainnet;
            return explorer.color;
        }

        // ==================== Navigation ====================
        let currentPage = 'home';
        let searchQuery = '';
        let searchFilter = 'all';

        function showPage(page, params = {}) {
            // Hide all pages
            document.querySelectorAll('[id^="page-"]').forEach(el => el.classList.add('hidden'));
            
            // Show target page
            const targetPage = document.getElementById(`page-${page}`);
            if (targetPage) {
                targetPage.classList.remove('hidden');
            }
            
            // Update nav links
            document.querySelectorAll('.nav-link').forEach(link => {
                link.classList.remove('active');
                if (link.dataset.page === page) {
                    link.classList.add('active');
                }
            });
            
            currentPage = page;
            
            // Load data for page
            if (page.startsWith('right-detail') && params.id) {
                loadRightDetail(params.id);
            } else if (page.startsWith('transfer-detail') && params.id) {
                loadTransferDetail(params.id);
            } else if (page.startsWith('seal-detail') && params.id) {
                loadSealDetail(params.id);
            } else if (page.startsWith('contract-detail') && params.id) {
                loadContractDetail(params.id);
            } else {
                loadData(page);
            }
            
            // Scroll to top
            window.scrollTo(0, 0);
        }

        // ==================== Data Loading ====================
        async function loadData(page) {
            try {
                switch(page) {
                    case 'home': await loadHome(); break;
                    case 'rights': await loadRights(); break;
                    case 'transfers': await loadTransfers(); break;
                    case 'seals': await loadSeals(); break;
                    case 'contracts': await loadContracts(); break;
                    case 'stats': await loadStats(); break;
                }
            } catch (error) {
                console.error(`Error loading ${page}:`, error);
                showToast('Failed to load data', 'error');
            }
        }

        // ==================== Copy to Clipboard ====================
        async function copyToClipboard(text, label = 'ID') {
            try {
                await navigator.clipboard.writeText(text);
                showToast(`${label} copied to clipboard!`, 'success');
            } catch (err) {
                // Fallback for older browsers
                const textarea = document.createElement('textarea');
                textarea.value = text;
                document.body.appendChild(textarea);
                textarea.select();
                document.execCommand('copy');
                document.body.removeChild(textarea);
                showToast(`${label} copied to clipboard!`, 'success');
            }
        }

        function createCopyButton(id, label = 'ID') {
            return `<button onclick="copyToClipboard('${id}', '${label}')" 
                            class="copy-btn ml-2 p-1 bg-gray-700 hover:bg-gray-600 rounded text-xs transition-all"
                            title="Copy ${label}">
                        📋
                    </button>`;
        }

        // ==================== External Explorer Links ====================
        function createExplorerLink(chain, type, hash) {
            const explorer = CHAIN_EXPLORERS[chain.toLowerCase()];
            if (!explorer) return hash;
            
            const url = explorer[type](hash);
            return `<a href="${url}" target="_blank" 
                        class="text-blue-400 hover:text-blue-300 underline flex items-center gap-1"
                        title="View on ${explorer.name} Explorer">
                        ${hash.substring(0, 20)}...
                        <span class="text-xs">↗</span>
                    </a>`;
        }

        function createChainBadge(chain) {
            const color = getExplorerColor(chain);
            const icon = getExplorerIcon(chain);
            return `<span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium" 
                          style="background-color: ${color}20; color: ${color}">
                        ${icon} ${chain}
                    </span>`;
        }

        // ==================== Toast Notifications ====================
        function showToast(message, type = 'info') {
            const container = document.getElementById('toast-container');
            const colors = {
                success: 'bg-green-600',
                error: 'bg-red-600',
                info: 'bg-blue-600',
                warning: 'bg-yellow-600'
            };
            
            const toast = document.createElement('div');
            toast.className = `${colors[type]} text-white px-6 py-3 rounded-lg shadow-lg mb-2`;
            toast.textContent = message;
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.3s';
                setTimeout(() => container.removeChild(toast), 300);
            }, 3000);
        }

        // ==================== Search ====================
        function performSearch() {
            searchQuery = document.getElementById('global-search').value.trim().toLowerCase();
            searchFilter = document.getElementById('search-filter').value;
            
            const infoDiv = document.getElementById('search-results-info');
            if (searchQuery) {
                infoDiv.classList.remove('hidden');
                infoDiv.innerHTML = `Searching for: <span class="text-blue-400">${searchQuery}</span>`;
                
                // Search across all data types
                searchAllData();
            } else {
                infoDiv.classList.add('hidden');
            }
        }

        function clearSearch() {
            document.getElementById('global-search').value = '';
            document.getElementById('search-filter').value = 'all';
            document.getElementById('search-results-info').classList.add('hidden');
            searchQuery = '';
            searchFilter = 'all';
            showPage('home');
        }

        async function searchAllData() {
            try {
                const [rightsResp, transfersResp, sealsResp] = await Promise.all([
                    fetch(`${API_URL}/api/v1/rights?limit=100`),
                    fetch(`${API_URL}/api/v1/transfers?limit=100`),
                    fetch(`${API_URL}/api/v1/seals?limit=100`)
                ]);
                
                const rights = (await rightsResp.json()).data.data || [];
                const transfers = (await transfersResp.json()).data.data || [];
                const seals = (await sealsResp.json()).data.data || [];
                
                let results = [];
                
                // Filter and search rights
                results = results.concat(rights.filter(r => 
                    matchesSearch(r) && matchesChainFilter(r.chain)
                ).map(r => ({
                    type: 'Right',
                    id: r.id,
                    title: `Right: ${r.id.substring(0, 20)}...`,
                    chain: r.chain,
                    status: r.status,
                    page: 'right-detail',
                    params: { id: r.id }
                })));
                
                // Filter and search transfers
                results = results.concat(transfers.filter(t => 
                    matchesSearch(t) && matchesChainFilter(t.from_chain)
                ).map(t => ({
                    type: 'Transfer',
                    id: t.id,
                    title: `Transfer: ${t.from_chain} → ${t.to_chain}`,
                    chain: t.from_chain,
                    status: t.status,
                    page: 'transfer-detail',
                    params: { id: t.id }
                })));
                
                // Filter and search seals
                results = results.concat(seals.filter(s => 
                    matchesSearch(s) && matchesChainFilter(s.chain)
                ).map(s => ({
                    type: 'Seal',
                    id: s.id,
                    title: `Seal: ${s.id.substring(0, 20)}...`,
                    chain: s.chain,
                    status: s.status,
                    page: 'seal-detail',
                    params: { id: s.id }
                })));
                
                // Display results
                displaySearchResults(results);
                
            } catch (error) {
                console.error('Search failed:', error);
                showToast('Search failed', 'error');
            }
        }

        function matchesSearch(item) {
            if (!searchQuery) return true;
            const searchable = JSON.stringify(item).toLowerCase();
            return searchable.includes(searchQuery);
        }

        function matchesChainFilter(chain) {
            if (searchFilter === 'all') return true;
            return chain.toLowerCase() === searchFilter;
        }

        function displaySearchResults(results) {
            const infoDiv = document.getElementById('search-results-info');
            infoDiv.innerHTML = `Found <span class="text-blue-400">${results.length}</span> results for: <span class="text-blue-400">${searchQuery}</span>`;
            
            // Create results page if needed
            if (!document.getElementById('page-search-results')) {
                const main = document.querySelector('main');
                const resultsPage = document.createElement('div');
                resultsPage.id = 'page-search-results';
                resultsPage.className = 'hidden';
                main.appendChild(resultsPage);
            }
            
            const resultsDiv = document.getElementById('search-results-content') || document.createElement('div');
            resultsDiv.id = 'search-results-content';
            resultsDiv.className = 'space-y-4';
            
            if (results.length === 0) {
                resultsDiv.innerHTML = '<div class="card rounded-xl p-8 text-center text-gray-400">No results found</div>';
            } else {
                resultsDiv.innerHTML = results.map(r => `
                    <div class="card rounded-xl p-4 clickable hover:bg-gray-800/50 transition-colors" 
                         onclick="showPage('${r.page}', ${JSON.stringify(r.params).replace(/"/g, '&quot;')})">
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-sm font-medium">${r.type}</span>
                                    ${createChainBadge(r.chain)}
                                    <span class="badge badge-${r.status}">${r.status}</span>
                                </div>
                                <div class="text-sm text-gray-400">${r.title}</div>
                            </div>
                            <span class="text-blue-400">→</span>
                        </div>
                    </div>
                `).join('');
            }
            
            document.getElementById('page-search-results').innerHTML = `
                <div class="mb-6">
                    <button onclick="clearSearch()" class="text-blue-400 hover:text-blue-300 mb-4">← Clear Search</button>
                    <h2 class="text-2xl font-bold mb-4">Search Results</h2>
                </div>
                ${resultsDiv.outerHTML}
            `;
            
            showPage('search-results');
        }

        // ==================== Health Check ====================
        async function checkHealth() {
            try {
                const resp = await fetch(`${API_URL}/health`);
                if (resp.ok) {
                    document.getElementById('api-status').innerHTML = '<span class="text-green-400">● Connected</span>';
                    if (currentPage === 'home') await loadHome();
                }
            } catch (e) {
                document.getElementById('api-status').innerHTML = '<span class="text-red-400">● Disconnected</span>';
            }
        }

        // ==================== Home Page ====================
        async function loadHome() {
            try {
                const resp = await fetch(`${API_URL}/api/v1/stats`);
                const json = await resp.json();
                const stats = json.data;

                document.getElementById('stat-rights').textContent = stats.total_rights;
                document.getElementById('stat-transfers').textContent = stats.total_transfers;
                document.getElementById('stat-seals').textContent = stats.total_seals;
                document.getElementById('stat-contracts').textContent = stats.total_contracts;

                // Chain status with external links
                const chainDiv = document.getElementById('chain-status');
                chainDiv.innerHTML = stats.rights_by_chain.map(rc => {
                    const explorer = CHAIN_EXPLORERS[rc.chain.toLowerCase()] || { name: rc.chain, icon: '●', color: '#6b7280' };
                    return `
                        <div class="card rounded-xl p-4 chain-link clickable" onclick="filterByChain('${rc.chain}')">
                            <div class="flex items-center gap-2 mb-2">
                                <span class="w-2 h-2 rounded-full bg-green-500"></span>
                                <span class="font-medium">${explorer.icon} ${explorer.name}</span>
                            </div>
                            <div class="text-sm text-gray-400">${rc.count} rights</div>
                            <div class="text-xs text-blue-400 mt-2">View on ${explorer.name} Explorer ↗</div>
                        </div>
                    `;
                }).join('');

                await loadActivity();
            } catch (e) {
                console.error('Failed to load home:', e);
            }
        }

        function filterByChain(chain) {
            document.getElementById('search-filter').value = chain.toLowerCase();
            document.getElementById('global-search').value = '';
            showPage('rights');
            loadRights();
        }

        // ==================== Activity Feed ====================
        async function loadActivity() {
            try {
                const [rightsResp, transfersResp, sealsResp] = await Promise.all([
                    fetch(`${API_URL}/api/v1/rights?limit=10`),
                    fetch(`${API_URL}/api/v1/transfers?limit=10`),
                    fetch(`${API_URL}/api/v1/seals?limit=10`)
                ]);

                const rightsJson = await rightsResp.json();
                const transfersJson = await transfersResp.json();
                const sealsJson = await sealsResp.json();

                const rights = rightsJson.data.data || [];
                const transfers = transfersJson.data.data || [];
                const seals = sealsJson.data.data || [];

                const activities = [
                    ...rights.map(r => ({
                        type: 'right',
                        icon: '📜',
                        title: `Right Created`,
                        subtitle: r.id,
                        chain: r.chain,
                        status: r.status,
                        time: new Date(r.created_at),
                        details: `Owner: ${r.owner.substring(0, 20)}...`,
                        page: 'right-detail',
                        params: { id: r.id }
                    })),
                    ...transfers.map(t => ({
                        type: 'transfer',
                        icon: '🔄',
                        title: `Transfer ${t.status}`,
                        subtitle: `${t.from_chain} → ${t.to_chain}`,
                        chain: t.from_chain,
                        status: t.status,
                        time: new Date(t.created_at),
                        details: `Right: ${t.right_id.substring(0, 20)}...`,
                        page: 'transfer-detail',
                        params: { id: t.id }
                    })),
                    ...seals.map(s => ({
                        type: 'seal',
                        icon: s.status === 'consumed' ? '🔓' : '🔒',
                        title: `Seal ${s.status === 'consumed' ? 'Consumed' : 'Created'}`,
                        subtitle: s.id,
                        chain: s.chain,
                        status: s.seal_type,
                        time: s.consumed_at ? new Date(s.consumed_at) : new Date(),
                        details: `Type: ${s.seal_type}, Block: ${s.block_height}`,
                        page: 'seal-detail',
                        params: { id: s.id }
                    }))
                ].sort((a, b) => b.time - a.time).slice(0, 15);

                const feedDiv = document.getElementById('activity-feed');
                feedDiv.innerHTML = activities.map((act, i) => {
                    const timeAgo = getTimeAgo(act.time);
                    const statusClass = getStatusClass(act.type, act.status);
                    return `
                        <div class="px-6 py-4 border-b border-gray-800 hover:bg-gray-800/50 transition-colors clickable cursor-pointer ${i === 0 ? 'bg-green-500/5' : ''}"
                             onclick="showPage('${act.page}', ${JSON.stringify(act.params).replace(/"/g, '&quot;')})">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-4">
                                    <span class="text-2xl">${act.icon}</span>
                                    <div>
                                        <div class="flex items-center gap-2">
                                            <span class="text-sm font-medium text-gray-200">${act.title}</span>
                                            <span class="px-2 py-0.5 rounded-full text-xs ${statusClass}">${act.status}</span>
                                        </div>
                                        <div class="text-sm text-gray-400 mt-0.5 mono">${act.subtitle.substring(0, 40)}...</div>
                                        <div class="text-xs text-gray-500 mt-0.5">${act.details}</div>
                                    </div>
                                </div>
                                <div class="text-right">
                                    ${createChainBadge(act.chain)}
                                    <div class="text-xs text-gray-500 mt-1">${timeAgo}</div>
                                </div>
                            </div>
                        </div>
                    `;
                }).join('');
            } catch (e) {
                console.error('Failed to load activity:', e);
                document.getElementById('activity-feed').innerHTML = `
                    <div class="p-8 text-center text-gray-500">Failed to load activity</div>
                `;
            }
        }

        // ==================== Rights ====================
        async function loadRights() {
            const resp = await fetch(`${API_URL}/api/v1/rights?limit=50`);
            const json = await resp.json();
            const rights = json.data.data;

            document.getElementById('rights-count').textContent = `${rights.length} rights found`;

            const tbody = document.getElementById('rights-table');
            tbody.innerHTML = rights.map(right => `
                <tr class="hover:bg-gray-800/50">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-2">
                            <span class="mono text-sm text-blue-400 clickable" onclick="showPage('right-detail', {id: '${right.id}'})">
                                ${right.id.substring(0, 20)}...
                            </span>
                            ${createCopyButton(right.id, 'Right ID')}
                        </div>
                    </td>
                    <td class="px-6 py-4">${createChainBadge(right.chain)}</td>
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-2">
                            <span class="mono text-sm text-gray-300 truncate max-w-xs">${right.owner.substring(0, 16)}...</span>
                            ${createCopyButton(right.owner, 'Owner Address')}
                        </div>
                    </td>

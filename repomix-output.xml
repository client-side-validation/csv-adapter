    fn test_verify_block_merkle_root() {
        let txids = [[1u8; 32], [2u8; 32]];
        let merkle_root = compute_merkle_root(&txids).unwrap();
        assert!(verify_block_merkle_root(&txids, merkle_root));
        assert!(!verify_block_merkle_root(&txids, [0u8; 32]));

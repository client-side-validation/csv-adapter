//! Validation commands — verify consignments and proofs

use anyhow::Result;
use clap::Subcommand;

use crate::config::{Chain, Config};
use crate::output;
use crate::state::State;

#[derive(Subcommand)]
pub enum ValidateAction {
    /// Validate a consignment
    Consignment {
        /// Consignment file (JSON)
        file: String,
    },
    /// Validate a cross-chain proof
    Proof {
        /// Proof file
        proof: String,
        /// Chain to verify on

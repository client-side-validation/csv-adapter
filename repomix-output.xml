    fn test_extract_merkle_proof_empty_block() {
        let txid = [1u8; 32];
        let block_txids = vec![];
        let block_hash = [2u8; 32];
        let block_height = 100;

        let proof = extract_merkle_proof_from_block(txid, &block_txids, block_hash, block_height);
        assert!(proof.is_none());
    }

  <title>CSV Wallet Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --bg-primary: var(--vscode-editor-background, #1e1e1e);
      --bg-secondary: var(--vscode-editorWidget-background, #252526);
      --bg-tertiary: var(--vscode-dropdown-background, #3c3c3c);
      --text-primary: var(--vscode-foreground, #cccccc);
      --text-secondary: var(--vscode-descriptionForeground, #999999);
      --border-color: var(--vscode-panel-border, #454545);
      --accent-color: var(--vscode-textLink-foreground, #3794ff);
      --success-color: var(--vscode-terminal-ansiGreen, #89d185);
      --warning-color: var(--vscode-terminal-ansiYellow, #cca700);
      --error-color: var(--vscode-terminal-ansiRed, #f14c4c);
      --info-color: var(--vscode-terminal-ansiBlue, #3794ff);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: var(--vscode-font-family, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif);
      font-size: var(--vscode-font-size, 13px);
      color: var(--text-primary);
      background: var(--bg-primary);
      line-height: 1.5;
      padding: 16px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border-color);
    }

    .header h1 {
      font-size: 1.3em;
      font-weight: 600;
    }

    .header-actions {
      display: flex;
      gap: 8px;
    }

    .btn {
      padding: 6px 12px;
      border: 1px solid var(--border-color);
      border-radius: 4px;
      background: var(--bg-tertiary);
      color: var(--text-primary);
      cursor: pointer;
      font-size: 0.9em;
      transition: background 0.2s;
    }

    .btn:hover {
      background: var(--accent-color);
      color: white;
    }

    .btn-primary {
      background: var(--accent-color);
      color: white;
      border-color: var(--accent-color);
    }

    .btn-success {
      background: var(--success-color);
      color: white;
      border-color: var(--success-color);
    }

    .dashboard {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }

    .stat-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 16px;
    }

    .stat-card .label {
      font-size: 0.85em;
      color: var(--text-secondary);
      margin-bottom: 8px;
    }

    .stat-card .value {
      font-size: 1.5em;
      font-weight: 600;
    }

    .stat-card .change {
      font-size: 0.8em;
      margin-top: 4px;
    }

    .stat-card .change.positive {
      color: var(--success-color);
    }

    .stat-card .change.negative {
      color: var(--error-color);
    }

    .section {
      margin-bottom: 24px;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }

    .section-title {
      font-size: 1.1em;
      font-weight: 600;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .panel {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 16px;
    }

    .panel-title {
      font-size: 0.9em;
      font-weight: 600;
      margin-bottom: 12px;
      color: var(--text-secondary);
    }

    .balance-chart {
      height: 200px;
      position: relative;
    }

    .activity-list {
      list-style: none;
    }

    .activity-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
      border-bottom: 1px solid var(--border-color);
    }

    .activity-item:last-child {
      border-bottom: none;
    }

    .activity-info {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .activity-icon {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.9em;
    }

    .activity-icon.transfer {
      background: color-mix(in srgb, var(--info-color) 20%, transparent);
      color: var(--info-color);
    }

    .activity-icon.receive {
      background: color-mix(in srgb, var(--success-color) 20%, transparent);
      color: var(--success-color);
    }

    .activity-icon.send {
      background: color-mix(in srgb, var(--warning-color) 20%, transparent);
      color: var(--warning-color);
    }

    .activity-details .title {
      font-weight: 500;
    }

    .activity-details .subtitle {
      font-size: 0.8em;
      color: var(--text-secondary);
    }

    .activity-amount {
      font-weight: 600;
      font-family: var(--vscode-editor-font-family, 'Consolas', 'Monaco', monospace);
    }

    .activity-amount.positive {
      color: var(--success-color);
    }

    .activity-amount.negative {
      color: var(--error-color);
    }

    .quick-actions {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .quick-action {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 16px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
    }

    .quick-action:hover {
      background: var(--bg-tertiary);
      border-color: var(--accent-color);
    }

    .quick-action .icon {
      font-size: 1.5em;
      margin-bottom: 8px;
    }

    .quick-action .label {
      font-size: 0.85em;
      color: var(--text-secondary);
    }

    .chains-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 12px;
    }

    .chain-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 12px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .chain-icon {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 0.75em;
    }

    .chain-icon.ethereum { background: #627eea; color: white; }
    .chain-icon.bitcoin { background: #f7931a; color: white; }
    .chain-icon.aptos { background: #2dd8a3; color: white; }
    .chain-icon.sui { background: #6fbcf0; color: white; }
    .chain-icon.solana { background: #9945ff; color: white; }

    .chain-info .name {
      font-weight: 500;
    }

    .chain-info .balance {
      font-size: 0.85em;
      color: var(--text-secondary);
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 10px;
      font-size: 0.75em;
      font-weight: 500;
      text-transform: uppercase;
    }

    .status-badge.completed {
      background: color-mix(in srgb, var(--success-color) 20%, transparent);
      color: var(--success-color);
    }

    .status-badge.pending {
      background: color-mix(in srgb, var(--warning-color) 20%, transparent);
      color: var(--warning-color);
    }

    .status-badge.failed {
      background: color-mix(in srgb, var(--error-color) 20%, transparent);
      color: var(--error-color);
    }

    .empty-state {
      text-align: center;
      padding: 32px;
      color: var(--text-secondary);
    }

    /* Accessibility: Focus styles */
    .btn:focus,
    .quick-action:focus {
      outline: 2px solid var(--accent-color);
      outline-offset: 2px;
    }

    @media (max-width: 768px) {
      .grid-2 {
        grid-template-columns: 1fr;
      }

      .quick-actions {
        grid-template-columns: 1fr;
      }

      .dashboard {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      * {
        transition: none !important;
      }
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>CSV Wallet Dashboard</h1>
    <div class="header-actions">
      <button class="btn" id="refresh-btn" aria-label="Refresh dashboard">Refresh</button>
      <button class="btn btn-success" id="connect-btn" aria-label="Connect wallet">Connect Wallet</button>
    </div>
  </div>

  <!-- Summary Statistics -->
  <div class="dashboard">
    <div class="stat-card">
      <div class="label">Total Balance (USD)</div>
      <div class="value" id="total-balance">$0.00</div>
      <div class="change positive" id="balance-change">+0.00%</div>
    </div>
    <div class="stat-card">
      <div class="label">Total Rights</div>
      <div class="value" id="total-rights">0</div>
      <div class="change">Across 0 chains</div>
    </div>
    <div class="stat-card">
      <div class="label">Pending Transfers</div>
      <div class="value" id="pending-transfers">0</div>
      <div class="change">Requires attention</div>
    </div>
    <div class="stat-card">
      <div class="label">Network</div>
      <div class="value" id="network-name">Testnet</div>
      <div class="change">Last sync: Just now</div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="section">
    <div class="quick-actions">
      <div class="quick-action" id="action-create-right" tabindex="0" role="button" aria-label="Create new Right">
        <div class="icon">+</div>
        <div class="label">Create Right</div>
      </div>
      <div class="quick-action" id="action-transfer" tabindex="0" role="button" aria-label="Initiate transfer">
        <div class="icon">&#8644;</div>
        <div class="label">Cross-Chain Transfer</div>
      </div>
      <div class="quick-action" id="action-inspect" tabindex="0" role="button" aria-label="Inspect proofs">
        <div class="icon">&#9679;</div>
        <div class="label">Inspect Proof</div>
      </div>
    </div>
  </div>

  <!-- Main Content Grid -->
  <div class="grid-2">
    <!-- Balance Chart -->
    <div class="section">
      <div class="panel">
        <div class="panel-title">Balance Overview</div>
        <div class="balance-chart">
          <canvas id="balance-chart" aria-label="Balance chart showing asset distribution across chains" role="img"></canvas>
        </div>
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="section">
      <div class="panel">
        <div class="panel-title">Recent Activity</div>
        <ul class="activity-list" id="activity-list" aria-label="Recent wallet activity">
          <li class="activity-item">
            <div class="activity-info">
              <div class="activity-icon transfer">&#8644;</div>
              <div class="activity-details">
                <div class="title">Ethereum &rarr; Aptos</div>
                <div class="subtitle">Cross-chain transfer &middot; 2 hours ago</div>
              </div>
            </div>
            <div class="activity-amount negative">-100 ETH</div>
          </li>
          <li class="activity-item">
            <div class="activity-info">
              <div class="activity-icon receive">&darr;</div>
              <div class="activity-details">
                <div class="title">Right Created</div>
                <div class="subtitle">Ownership on Sui &middot; 5 hours ago</div>
              </div>
            </div>
            <div class="status-badge completed">Completed</div>
          </li>
          <li class="activity-item">
            <div class="activity-info">
              <div class="activity-icon send">&uarr;</div>
              <div class="activity-details">
                <div class="title">Aptos &rarr; Sui</div>
                <div class="subtitle">Pending transfer &middot; 1 day ago</div>
              </div>
            </div>
            <div class="status-badge pending">Pending</div>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Chain Balances -->
  <div class="section">
    <div class="panel">
      <div class="panel-title">Chain Balances</div>
      <div class="chains-grid" id="chains-grid">
        <div class="chain-card">
          <div class="chain-icon ethereum">ETH</div>
          <div class="chain-info">
            <div class="name">Ethereum</div>
            <div class="balance">0.00 ETH</div>
          </div>
        </div>
        <div class="chain-card">
          <div class="chain-icon aptos">APT</div>
          <div class="chain-info">
            <div class="name">Aptos</div>
            <div class="balance">0.00 APT</div>
          </div>
        </div>
        <div class="chain-card">
          <div class="chain-icon sui">SUI</div>
          <div class="chain-info">
            <div class="name">Sui</div>
            <div class="balance">0.00 SUI</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Initialize balance chart
    const ctx = document.getElementById('balance-chart');
    let balanceChart = null;

    function initChart() {
      if (balanceChart) {
        balanceChart.destroy();
      }

      balanceChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: ['Ethereum', 'Aptos', 'Sui'],
          datasets: [{
            data: [0, 0, 0],
            backgroundColor: ['#627eea', '#2dd8a3', '#6fbcf0'],
            borderWidth: 0,
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'bottom',
              labels: {
                color: getComputedStyle(document.body).getPropertyValue('--text-primary') || '#cccccc',
                padding: 16,
              }
            }
          }
        }
      });
    }

    // Quick action handlers
    document.getElementById('action-create-right').addEventListener('click', function() {
      vscode.postMessage({ command: 'createRight' });
    });

    document.getElementById('action-transfer').addEventListener('click', function() {
      vscode.postMessage({ command: 'transfer' });
    });

    document.getElementById('action-inspect').addEventListener('click', function() {
      vscode.postMessage({ command: 'inspectProof' });
    });

    document.getElementById('refresh-btn').addEventListener('click', function() {
      refreshDashboard();
      vscode.postMessage({ command: 'refresh' });
    });

    document.getElementById('connect-btn').addEventListener('click', function() {
      vscode.postMessage({ command: 'connectWallet' });
    });

    // Keyboard support for quick actions
    document.querySelectorAll('.quick-action').forEach(function(action) {
      action.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          this.click();
        }
      });
    });

    function refreshDashboard() {
      // Simulated refresh - in production, fetch actual data
      updateStats();
    }

    function updateStats() {
      // Update with mock data
      document.getElementById('total-balance').textContent = '$0.00';
      document.getElementById('total-rights').textContent = '0';
      document.getElementById('pending-transfers').textContent = '0';
    }

    // Listen for messages from VS Code
    window.addEventListener('message', function(event) {
      const message = event.data;
      
      switch (message.command) {
        case 'updateBalances':
          updateBalances(message.data);
          break;
        case 'updateActivity':
          updateActivity(message.data);
          break;
        case 'updateChains':
          updateChains(message.data);
          break;
      }
    });

    function updateBalances(data) {
      document.getElementById('total-balance').textContent = '$' + data.total.toFixed(2);
      
      if (balanceChart) {
        balanceChart.data.datasets[0].data = data.chains.map(function(c) { return c.balance; });
        balanceChart.update();
      }
    }

    function updateActivity(data) {
      const list = document.getElementById('activity-list');
      list.innerHTML = '';
      
      data.forEach(function(item) {
        const li = document.createElement('li');
        li.className = 'activity-item';
        li.innerHTML = '<div class="activity-info">' +
          '<div class="activity-icon ' + item.type + '">' + getIcon(item.type) + '</div>' +
          '<div class="activity-details">' +
          '<div class="title">' + item.title + '</div>' +
          '<div class="subtitle">' + item.subtitle + '</div>' +
          '</div>' +
          '</div>' +
          (item.amount ? '<div class="activity-amount ' + (item.amount > 0 ? 'positive' : 'negative') + '">' + formatAmount(item.amount) + '</div>' : '');
        list.appendChild(li);
      });
    }

    function updateChains(data) {
      const grid = document.getElementById('chains-grid');
      grid.innerHTML = '';
      
      data.forEach(function(chain) {
        const div = document.createElement('div');
        div.className = 'chain-card';
        div.innerHTML = '<div class="chain-icon ' + chain.id + '">' + chain.symbol + '</div>' +
          '<div class="chain-info">' +
          '<div class="name">' + chain.name + '</div>' +
          '<div class="balance">' + chain.balance.toFixed(2) + ' ' + chain.symbol + '</div>' +
          '</div>';
        grid.appendChild(div);
      });
    }

    function getIcon(type) {
      switch (type) {
        case 'transfer': return '&#8644;';
        case 'receive': return '&darr;';
        case 'send': return '&uarr;';
        default: return '&#9679;';
      }
    }

    function formatAmount(amount) {
      const prefix = amount > 0 ? '+' : '';
      return prefix + amount.toFixed(2);
    }

    // Initialize on load
    initChart();
    updateStats();

    // VS Code API (provided by the webview)
    const vscode = acquireVsCodeApi();
  </script>
</body>
</html>

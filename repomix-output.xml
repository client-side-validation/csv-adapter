    fn test_verify_event_failed_tx() {
        let rpc = MockSuiRpc::new(1000);
        rpc.add_transaction(SuiTransactionBlock {
            digest: [1u8; 32],
            checkpoint: Some(100),
            effects: SuiTransactionEffects {
                status: SuiExecutionStatus::Failure {

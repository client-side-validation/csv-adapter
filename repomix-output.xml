                        div { class: "space-y-3",
                            {s.rights_by_chain.iter().map(|rc| rsx! {
                                ChainBar {
                                    key: "{rc.chain}",
                                    chain: rc.chain.clone(),
                                    count: rc.count,
                                    max: s.rights_by_chain.first().map(|c| c.count).unwrap_or(1),

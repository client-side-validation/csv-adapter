                        div { class: "text-center",
                            div { class: "text-5xl font-bold text-green-400 mb-2",
                                {format!("{:.1}%", s.transfer_success_rate)}
                            }
                            if let Some(avg_ms) = s.average_transfer_time_ms {
                                div { class: "text-gray-400 text-sm",
